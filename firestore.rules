rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isSignedIn();
      // Allow user to create their profile, but NOT set isAdmin to true unless they are already an admin
      allow create: if isSignedIn() && (request.resource.data.isAdmin == false || isAdmin());
      // Prevent regular users from promoting themselves to admin
      allow update: if isSignedIn() && (
        (isOwner(userId) && request.resource.data.isAdmin == resource.data.isAdmin) ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Products collection
    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();

      // Reviews sub-collection
      match /reviews/{reviewId} {
        allow read: if true;
        // Review ID is the User UID
        allow create: if isSignedIn() && reviewId == request.auth.uid
                      && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isSignedIn() && (reviewId == request.auth.uid || isAdmin());
      }
    }

    // Categories collection
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders collection
    match /orders/{orderId} {
      // Users can only see their own orders. Admins see all.
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      // Only users can create their own orders
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      // Only admins can update status or delete
      allow update, delete: if isAdmin();
    }
  }
}
